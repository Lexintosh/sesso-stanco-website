---
// src/layouts/Layout.astro
import '../styles/global.css';
const { title } = Astro.props;
---

<!doctype html>
<html lang="it" class="bg-black text-white selection:bg-white selection:text-black">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <!-- IL FIX DELLA FAVICON È QUI SOTTO -->
    <link rel="icon" type="image/png" href="/favicon.png" />
    
    <title>{title} | SESSO STANCO RECORDS</title>
  </head>
  <body class="bg-black text-white font-mono antialiased p-2 md:p-6 min-h-screen flex flex-col">
    <!-- Main Shell -->
    <div class="border-8 border-white p-2 flex-grow flex flex-col justify-between">
      <div class="border-4 border-white p-4 md:p-6 flex-grow flex flex-col">
        <slot />
      </div>
    </div>
  </body>
</html>